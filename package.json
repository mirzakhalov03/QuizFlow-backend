{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"ts-node ./src/server.ts\"",
    "worker:dev": "nodemon --watch src --ext ts --exec \"ts-node ./src/workers/feedbackWorker.ts\"",
    "worker:start": "node ./dist/src/workers/feedbackWorker.js",
    "build": "tsc",
    "build:lambda": "ts-node ./scripts/build-lambda.ts",
    "deploy:lambda": "ts-node ./scripts/deploy-lambda.ts",
    "start": "node ./dist/src/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "ts-node ./src/database/migrate.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true",
    "validate": "npm run format && npm run lint:fix && npm run prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:int": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ],
    "*.{ts,js,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.895.0",
    "@aws-sdk/client-s3": "^3.895.0",
    "@aws-sdk/client-sqs": "^3.1070.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@notionhq/client": "^5.20.0",
    "@sentry/node": "^10.56.0",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.6",
    "debug": "~2.6.9",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "~4.16.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "highlight.js": "^11.11.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.4",
    "openai": "^6.38.0",
    "pg": "^8.20.0",
    "puppeteer": "^24.10.0",
    "redis": "^6.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@aws-sdk/client-ec2": "^3.1045.0",
    "@aws-sdk/client-rds": "^3.1045.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "@types/adm-zip": "^0.5.7",
    "@types/bcryptjs": "^2.4.2",
    "@types/chai": "^5.2.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/highlight.js": "^9.12.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.7",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.9",
    "chai": "^6.2.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.9"
  }
}
